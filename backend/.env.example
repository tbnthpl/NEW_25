# =============================================================================
# Doorstep Banking - backend environment template
# Copy to backend/.env and fill in real values for the target environment.
# Anything left commented uses the in-code default.
# =============================================================================

# -- Oracle (REQUIRED in UAT/prod; the in-code default points at a local XE
#    instance with a well-known password and MUST NOT be used in shared envs).
# DATABASE_URL=oracle+oracledb://USER:PASS@host:1521/?service_name=SERVICE

# -- CORS: comma-separated list of allowed front-end origins. Required when the
#    UI is served from a host other than the API. Wildcards are rejected because
#    cookies (allow_credentials=True) are incompatible with "*".
# CORS_ORIGINS=https://dsb-uat.federalbank.co.in,https://dsb-uat-admin.federalbank.co.in

# -- Auth cookie. Set AUTH_COOKIE_SECURE=true the moment UAT is on HTTPS so the
#    session cookie is never sent over plain HTTP.
# AUTH_COOKIE_NAME=dsb_auth
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=lax
# AUTH_TOKEN_TTL_MINUTES=480
# AUTH_PERSIST_TOKENS=true        # H13: write tokens to dsb_user_session

# -- Login throttling / lockout.
# LOGIN_RATE_WINDOW_SEC=60
# LOGIN_MAX_PER_IP_PER_MIN=20
# LOGIN_MAX_PER_USER_PER_MIN=8
# LOGIN_LOCKOUT_FAILS=10
# LOGIN_LOCKOUT_SEC=300
# LOGIN_FAIL_FLOOR_MS=750         # constant-time delay floor on failed login

# -- Health check.
#    /api/health/db now requires either an authenticated user or this token via
#    X-Internal-Health-Token; leave empty to require auth.
# HEALTH_DB_INTERNAL_TOKEN=

# -- Bulk Excel uploads — hard cap on rows/file (DoS guard).
# EXCEL_MAX_ROWS=200000

# -- Content-Security-Policy override (defaults to a reasonably strict policy
#    permitting jsdelivr for the xlsx library).
# CSP_HEADER=...

# -- Bank AD SOAP login. AD_VERIFY_SSL MUST be true for any non-local deployment.
# AD_SOAP_ENDPOINT=https://10.250.7.210:443/SSO/ADLogin.asmx
# AD_SOAP_ACTION=http://tempuri.org/userAttributes
# AD_VERIFY_SSL=true
# AD_TIMEOUT=30

# -- Local-dev ONLY. NEVER set in UAT/preprod/prod (the app refuses AD_SKIP when
#    ENVIRONMENT is one of uat/preprod/prod). Any non-empty password is accepted
#    for ACTIVE users in dsb_user_account when this is enabled.
# AD_SKIP=true
# ENVIRONMENT=local

# -- Diagnostics: log raw AD SOAP responses (verbose; turn off in normal use).
# AD_DEBUG=true
